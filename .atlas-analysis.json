  "keyFeatures": [
    "JWT-based authentication with role-based access control (admin, cajero)",
    "Transaction management with item, extra, and payment tracking",
    "Cash register (caja) lifecycle: open, manage expenses, close with reconciliation",
    "Menu management with dish-ingredient relationships and stock deduction",
    "Real-time kitchen display via Socket.IO WebSocket gateway (/cocina namespace)",
    "Dashboard with real-time stats: daily revenue, open orders, recent activity",
    "Drizzle ORM with PostgreSQL 17 and automated migrations",
    "Docker Compose setup for local and production environments",
    "Soft-delete pattern across all entities for data integrity",
    "Bolivia (America/La_Paz) timezone handling throughout the system"
  ],
  "publicApiSurface": [
    "POST /api/auth/login",
